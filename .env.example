# ============================================================
# MailTrustAI — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ============================================================

PORT=3000
NODE_ENV=production

MSA_ENC_PASSWORD=
MSA_ENC_SALT=
MSA_LICENSE_SECRET=
MSA_ADMIN_TOKEN_SECRET=
MSA_RECOVERY_EMAIL=

# İlk kurulum (uzaktan ilk şifre belirleme) için tek seferlik token.
# Kurulum scripti otomatik üretir; her iki şifre (admin + müşteri) belirlendikten
# sonra bu satırı silmeniz veya değerini boşaltmanız önerilir.
# Boş ise yalnızca localhost erişimi ile ilk şifre belirlenebilir.
MSA_SETUP_TOKEN=

MSA_LICENSE_REMOTE_URL=
MSA_LICENSE_REFRESH_MS=21600000
MSA_LICENSE_GRACE_MS=259200000

# Müşteri kurulumu modu: keygen/bayi panelleri ve lisans-üretici API'leri kapatılır.
# - /keygen.html, /bayi.html → 404
# - /api/dealer/*, /api/license/{generate,batch,trial,revoke,...} → 404
# Müşteri kurulum scripti otomatik 'true' yapar.
MSA_CUSTOMER_ONLY=false
