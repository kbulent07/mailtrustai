# =============================================================
# Host'taki Windows-derlenmiş node_modules ve runtime data
# container'a sızdırılmamalı (invalid ELF header sebebi).
# =============================================================

# Bağımlılıklar — container kendi yükler (Linux platformu için).
node_modules/
**/node_modules/

# Sensitive env files
.env
.env.local
.env.*.local
.env.docker
.env.docker.local

# Runtime data/log volumes
data/
logs/
**/data/
**/logs/
*.log
npm-debug.log*

# Git / IDE
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
.claude/

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts
dist/
build/
coverage/
.nyc_output/

# PM2 (Docker'da kullanılmaz)
ecosystem.config.js
.pm2/

# Compose ve diğer Dockerfile'lar image context'inden hariç
# (sadece ilgili Dockerfile build sırasında kullanılır).
docker-compose*.yml
Dockerfile.test

# Kurulum betikleri (image'a ihtiyaç yok)
install/

# Docs (image'a ihtiyaç yok)
docs/
*.md
nginx/certs/
