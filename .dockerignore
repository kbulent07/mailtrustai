# Sensitive env files
.env
.env.local
.env.*.local

# Runtime data/log volumes
data/
logs/
*.log
npm-debug.log*

# Git / IDE
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts
dist/
build/

# Tests and local dev-only files
*.test.js
*.spec.js
.claude/

# PM2 (not used in Docker)
ecosystem.config.js
.pm2/

# Keep docs and compose out of image context
docs/
*.md
docker-compose*.yml
nginx/
