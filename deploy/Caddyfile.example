# =============================================================
# MailTrustAI — Caddy reverse proxy (mailtrustai.com)
#
# Caddy otomatik Let's Encrypt sertifikası alır.
# Kurulum:
#   sudo apt install -y caddy
#   sudo cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# DNS A kayıtları (DNS sağlayıcınızda):
#   license.mailtrustai.com   → SUNUCU_IP
#   bayi.mailtrustai.com      → SUNUCU_IP
#
# Firewall (UFW):
#   sudo ufw allow 80,443/tcp
#   sudo ufw deny 3100,3200/tcp   # localhost-only — Caddy proxylesin
# =============================================================

# License-server:
#   - Müşteri/bayi API'si  → /api/*
#   - Merkezi yönetim SPA  → /admin/* (yalnız sizin IP'niz erişebilir)
#   - Sağlık kontrolü      → /healthz
license.mailtrustai.com {
    encode gzip

    reverse_proxy localhost:3200 {
        header_up X-Real-IP {remote_host}
        health_uri /healthz
        health_interval 30s
        health_timeout 5s
    }

    # /admin/* sadece güvenilir IP'lerden (kendi ofis/VPN IP'nizi girin)
    # Birden fazla IP için: remote_ip 1.2.3.4/32 5.6.7.8/32
    @adminPath path /admin /admin/*
    @notTrusted {
        path /admin /admin/*
        not remote_ip 127.0.0.1/8 ::1
        # İstediğiniz IP bloğunu aşağıya ekleyin, örnek:
        # not remote_ip 192.0.2.10/32
    }
    respond @notTrusted "Erişim reddedildi" 403

    # /api, /admin, /healthz dışı tüm path'ler → 404
    @notAllowed not path /api/* /admin /admin/* /healthz /health
    respond @notAllowed 404

    log {
        output file /var/log/caddy/license-access.log
        format json
    }
}

# Dealer panel: bayi kullanıcılarının yönetim arayüzü
# Opsiyonel: belirli IP bloklarına kısıtlayın
bayi.mailtrustai.com {
    encode gzip
    reverse_proxy localhost:3100 {
        header_up X-Real-IP {remote_host}
        health_uri /healthz
    }
    log {
        output file /var/log/caddy/bayi-access.log
        format json
    }
    # Bayi paneli için ek IP allowlist (opsiyonel — kendi IP'nizi ekleyin)
    # @blocked not remote_ip 192.0.2.0/24
    # respond @blocked 403
}

# Default: sunucu kök domain için basit landing
mailtrustai.com, www.mailtrustai.com {
    respond "MailTrustAI" 200
}
