# =============================================================
# MailTrustAI — Nginx reverse proxy (mailtrustai.com)
# Alternatif: Caddy (deploy/Caddyfile.example) — otomatik SSL.
#
# Kurulum (manuel SSL):
#   sudo apt install -y nginx certbot python3-certbot-nginx
#   sudo cp deploy/nginx-server.conf.example /etc/nginx/sites-available/mailtrustai
#   sudo ln -s /etc/nginx/sites-available/mailtrustai /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d license.mailtrustai.com -d bayi.mailtrustai.com
# =============================================================

# Upstream tanımları
upstream mailtrustai_license_server {
    server 127.0.0.1:3200;
    keepalive 32;
}
upstream mailtrustai_dealer {
    server 127.0.0.1:3100;
    keepalive 32;
}

# Genel: HTTP → HTTPS yönlendirme (certbot yapısı bozulmasın diye well-known korunur)
server {
    listen 80;
    server_name license.mailtrustai.com bayi.mailtrustai.com mailtrustai.com www.mailtrustai.com;
    location /.well-known/acme-challenge/ { root /var/www/html; }
    location / { return 301 https://$host$request_uri; }
}

# === License-Server (müşteri & dealer API) ===
server {
    listen 443 ssl http2;
    server_name license.mailtrustai.com;

    ssl_certificate     /etc/letsencrypt/live/license.mailtrustai.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/license.mailtrustai.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Güvenlik başlıkları
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    client_max_body_size 1m;

    location /healthz {
        proxy_pass http://mailtrustai_license_server;
        access_log off;
    }

    location /api/ {
        proxy_pass http://mailtrustai_license_server;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;
    }

    # Merkezi Yönetim Paneli — sadece güvenilir IP'lerden erişim
    # Kendi ofis/VPN IP bloğunuzu aşağıya ekleyin (allow satırı):
    location /admin {
        # allow 203.0.113.10;   # <-- ofis/VPN IP'niz
        allow 127.0.0.1;
        allow ::1;
        deny  all;
        proxy_pass http://mailtrustai_license_server;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / { return 404; }  # /api ve /admin dışı path yok
}

# === Dealer Panel (bayi kullanıcıları) ===
server {
    listen 443 ssl http2;
    server_name bayi.mailtrustai.com;

    ssl_certificate     /etc/letsencrypt/live/bayi.mailtrustai.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bayi.mailtrustai.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:;" always;

    client_max_body_size 2m;

    location / {
        proxy_pass http://mailtrustai_dealer;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # WebSocket (gelecekte gerekirse)
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_connect_timeout 10s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }
}

# === Domain kök (opsiyonel, landing page) ===
server {
    listen 443 ssl http2;
    server_name mailtrustai.com www.mailtrustai.com;

    ssl_certificate     /etc/letsencrypt/live/mailtrustai.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mailtrustai.com/privkey.pem;

    location / { return 200 "MailTrustAI\n"; }
}
