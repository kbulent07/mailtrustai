    "openaiAnalysis": {
      "threatLevel": "medium",
      "category": "other",
      "confidence": 60,
      "maliciousIntentScore": 40,
      "summaryTR": "E-posta, çok sayıda ek ve büyük boyutlu bir mesaj içeriyor. SPF, DKIM ve DMARC doğrulamaları eksik ve potansiyel risk taşıyabilir.",
      "summaryEN": "The email contains a large number of attachments and is unusually large in size. It lacks SPF, DKIM, and DMARC verification, which may indicate potential risk.",
      "attackNarrativeTR": "Çok sayıda ek içeren ve kimlik doğrulaması eksik olan bu tür e-postalar, zararlı yazılım yayma, bilgi sızdırma veya oltalama amacıyla kullanılabilir. Özellikle 'docx' uzantılı dosyalar istismar edilebilir.",
      "attackNarrativeEN": "Emails containing numerous attachments and lacking sender authentication are sometimes used for malware delivery, data theft, or phishing. The 'docx' attachments are especially noteworthy as common vectors for malicious macros or exploits.",
      "redFlagsTR": [
        "Çok fazla ek bulunuyor (49 adet)",
        "Kimlik doğrulama (SPF/DKIM/DMARC) yok",
        "Büyük boyutlu ve birden çok doküman dosyası",
        "Konunun ticari tekliflere ilişkin olması, sosyal mühendislik riski doğurabilir"
      ],
      "socialEngineeringSignalsTR": [
        "Yetkili bir departmana yönelik gibi görünüyor",
        "İş teklifi veya sözleşme eklerinin olması, işlem yapmaya teşvik edebilir"
      ],
      "requestedActionsTR": [
        "Ekleri açma veya indirme",
        "Muhtemelen sözleşme veya teklif ile ilgili bir dosyayı inceleme"
      ],
      "recommendedActionsTR": [
        "Ekler antivirüs ve sandbox üzerinden taranmalı",
        "Kimlik doğrulaması eksik olduğundan gönderen teyit edilmeli",
        "E-posta güvenlik ekiplerine iletilmeli ve açılmadan dikkatlice incelenmeli"
      ],
      "impersonationRisk": "medium",
      "financialRisk": "medium",
      "credentialRisk": "low",
      "urgencyRisk": "low",
      "_model": "gpt-4.1"
