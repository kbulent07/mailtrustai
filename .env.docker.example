# ============================================================
# MailTrustAI — Docker Compose env template
# Kullanım:
#   cp .env.docker.example .env.docker
#   # Tüm secret'ları üret:
#   #   openssl rand -hex 32   (her secret için yeni değer)
#   # Sonra:
#   docker compose --env-file .env.docker -f docker-compose.server.yml up -d --build
# ============================================================

# === Server-side secret'lar (zorunlu) ===
# license-core HMAC anahtarı — DEĞİŞTİRME (mevcut key'ler bozulur).
LICENSE_SIGNING_SECRET=
# Bearer token: dealer→license-server ve admin→license-server.
DEALER_API_SECRET=
# Dealer panel HMAC cookie imzası.
DEALER_SESSION_SECRET=

# === MariaDB ===
MARIADB_DATABASE=mailtrustai_license
MARIADB_USER=mailtrustai
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

# === Port mapping (host) ===
LICENSE_SERVER_PORT=3200
DEALER_PORT=3100

# === Grace + heartbeat ===
DEFAULT_GRACE_DAYS=7
HEARTBEAT_ONLINE_THRESHOLD_SECONDS=300
HEARTBEAT_STALE_THRESHOLD_SECONDS=1800
CUSTOMER_SYNC_MAX_PAYLOAD_BYTES=16384
DEALER_SESSION_TTL_MINUTES=480

# ============================================================
# === Customer-side (docker-compose.customer.yml için) ===
# Müşterinin elindeki LISANS key — bayinin `/api/license/create`
# çıktısı buraya yapıştırılır.
MSA_LICENSE_KEY=
# Bayi/kurucu sunucusunun PUBLIC URL'i (TLS arkasında).
MSA_LICENSE_REMOTE_URL=https://license.mailtrustai.example.com
MSA_CENTRAL_SYNC_URL=
MSA_CENTRAL_SYNC_ENABLED=true
MSA_HEARTBEAT_INTERVAL_SECONDS=300
MSA_POLICY_SYNC_INTERVAL_SECONDS=900
# Lokal AES-256-GCM cache anahtarı (opsiyonel — boşsa hostname'den türetilir).
MSA_LOCAL_ENCRYPTION_KEY=
# IMAP credential şifrelemesi için (zorunlu — en az 32 karakter).
MSA_ENC_PASSWORD=
MSA_ENC_SALT=
# Legacy license HMAC (src/license/license.js — geriye dönük uyumluluk).
MSA_LICENSE_SECRET=
# Ilk admin kullanici kurulumu icin (container disindan setup): random uzun token.
# Browser'a girerken: http://musteri-host:3000/?setup_token=BU_DEGER
# Setup tamamlandiktan sonra silinebilir.
MSA_SETUP_TOKEN=

CUSTOMER_PORT=3000
