{
  "name": "mailtrustai-monorepo",
  "version": "2.0.0-mainpaketler.0",
  "private": true,
  "description": "MailTrustAI — 3 paketli ticari self-hosted mimari (customer / dealer / license-server)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node --use-system-ca apps/customer/server.js",
    "dev": "node --use-system-ca apps/customer/server.js",
    "dev:customer": "node --use-system-ca apps/customer/server.js",
    "dev:dealer": "node --use-system-ca apps/dealer/server.js",
    "dev:license": "node --use-system-ca apps/license-server/server.js",
    "test": "node --test --test-concurrency=1 \"tests/unit/*.test.js\" \"tests/integration/*.test.js\" \"tests/security/*.test.js\"",
    "test:parallel": "node --test \"tests/unit/*.test.js\" \"tests/integration/*.test.js\" \"tests/security/*.test.js\"",
    "test:legacy": "node --test \"tests/unit/*.test.js\"",
    "test:docker": "docker compose -f docker-compose.test.yml run --rm test",
    "test:docker:build": "docker compose -f docker-compose.test.yml build test",
    "test:docker:rebuild": "docker compose -f docker-compose.test.yml build --no-cache test && docker compose -f docker-compose.test.yml run --rm test",
    "build:customer": "docker build -f apps/customer/Dockerfile -t mailtrustai-customer:latest .",
    "build:dealer": "docker build -f apps/dealer/Dockerfile -t mailtrustai-dealer:latest .",
    "build:license": "docker build -f apps/license-server/Dockerfile -t mailtrustai-license-server:latest .",
    "up:server": "docker compose --env-file .env.docker -f docker-compose.server.yml up -d --build",
    "down:server": "docker compose -f docker-compose.server.yml down",
    "logs:server": "docker compose -f docker-compose.server.yml logs -f --tail=200",
    "up:customer": "docker compose --env-file .env.docker -f docker-compose.customer.yml up -d --build",
    "down:customer": "docker compose -f docker-compose.customer.yml down",
    "logs:customer": "docker compose -f docker-compose.customer.yml logs -f --tail=200",
    "check:customer-package": "node scripts/check-customer-package.js",
    "check:customer-package:image": "node scripts/check-customer-package.js --scope=image",
    "smoke:central-flow": "node scripts/smoke-central-flow.js",
    "precheck:release": "node scripts/release-precheck.js",
    "precheck:quick": "node scripts/release-precheck.js --skip-image-gate --skip-smoke",
    "precheck:ci": "node scripts/release-precheck.js --only-tests --json"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.0.160",
    "mailparser": "^3.6.9",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.7",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  }
}
