NODE_ENV=production
PORT=3000
MSA_CUSTOMER_ONLY=true

# Lisans
MSA_LICENSE_KEY=
MSA_LICENSE_REMOTE_URL=https://license.mailtrustai.com

# Merkezi sync (license-server ile aynı host olabilir)
MSA_CENTRAL_SYNC_URL=https://license.mailtrustai.com
MSA_CENTRAL_SYNC_ENABLED=true
MSA_INSTANCE_ID=
MSA_HEARTBEAT_INTERVAL_SECONDS=300
MSA_POLICY_SYNC_INTERVAL_SECONDS=900

# Local encrypted storage
MSA_LOCAL_ENCRYPTION_KEY=

# Veri/log dizinleri
DATA_DIR=/app/data
LOG_DIR=/app/logs
