NODE_ENV=production
PORT=3200
LICENSE_DB_CLIENT=mariadb

LICENSE_SIGNING_SECRET=
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=mailtrustai_license
MARIADB_USER=mailtrustai
MARIADB_PASSWORD=mailtrustai_change_me

# Dealer ve admin endpoint'leri için Bearer secret (tek; ileride per-dealer token tablosuna geçilebilir)
DEALER_API_SECRET=
TOKEN_SECRET=

# Grace
DEFAULT_GRACE_DAYS=7

# Heartbeat threshold (saniye)
HEARTBEAT_ONLINE_THRESHOLD_SECONDS=300
HEARTBEAT_STALE_THRESHOLD_SECONDS=1800

# Customer sync payload limit (byte)
CUSTOMER_SYNC_MAX_PAYLOAD_BYTES=16384

DATA_DIR=/app/data
