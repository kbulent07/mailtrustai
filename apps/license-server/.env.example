NODE_ENV=production
PORT=3200
LICENSE_DB_CLIENT=mariadb

LICENSE_SIGNING_SECRET=
LICENSE_DB_PATH=/app/data/license-server.sqlite
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=mailtrustai_license
MARIADB_USER=mailtrustai
MARIADB_PASSWORD=mailtrustai_change_me

# Dealer ve admin endpoint'leri için Bearer secret (tek; ileride per-dealer token tablosuna geçilebilir)
DEALER_API_SECRET=
TOKEN_SECRET=

# Grace
DEFAULT_GRACE_DAYS=7

# Heartbeat threshold (saniye)
HEARTBEAT_ONLINE_THRESHOLD_SECONDS=300
HEARTBEAT_STALE_THRESHOLD_SECONDS=1800

# Customer sync payload limit (byte) + recursion depth
CUSTOMER_SYNC_MAX_PAYLOAD_BYTES=16384
CUSTOMER_SYNC_MAX_DEPTH=8

# Rate limit — window (ms) + max request sayısı (her IP için)
# Boş bırakılırsa default'lar: activate 60000/20, validate 60000/60,
# heartbeat 300000/30, customer_sync 60000/30, auth 60000/10
# RATE_ACTIVATE_WINDOW_MS=60000
# RATE_ACTIVATE_MAX=20
# RATE_VALIDATE_WINDOW_MS=60000
# RATE_VALIDATE_MAX=60
# RATE_HEARTBEAT_WINDOW_MS=300000
# RATE_HEARTBEAT_MAX=30
# RATE_CUSTOMER_SYNC_WINDOW_MS=60000
# RATE_CUSTOMER_SYNC_MAX=30
# RATE_AUTH_WINDOW_MS=60000
# RATE_AUTH_MAX=10

# Express body limit (KB)
LICENSE_SERVER_JSON_LIMIT_KB=256

# Lists endpoint validation
LISTS_MAX_ENTRIES_PER_FIELD=10000
LISTS_MAX_BODY_BYTES=1048576

DATA_DIR=/app/data
