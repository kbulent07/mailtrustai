NODE_ENV=production
PORT=3100

# License-server adresi (compose içinde service adı, host'ta gerçek URL).
LICENSE_SERVER_URL=http://license-server:3200
# license-server DEALER_API_SECRET ile AYNI değer.
DEALER_API_TOKEN=
# HMAC cookie imzası — production'da zorunlu (boşsa boot'ta exit).
DEALER_SESSION_SECRET=
# Session TTL (dakika). Default 480 (8 saat).
DEALER_SESSION_TTL_MINUTES=480

# MVP demo login (production'da kullanılmaz, NODE_ENV=production'da kapalı).
# MSA_DEALER_AUTH_MODE=demo
DEALER_DEMO_USER=
DEALER_DEMO_PASS=

# HTTP body limit (KB)
DEALER_JSON_LIMIT_KB=128

# License-server'a istek zaman aşımı (ms)
LICENSE_SERVER_TIMEOUT_MS=15000
